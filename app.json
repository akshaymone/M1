{
  "expo": {
    "name": "M1",
    "slug": "M1",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.akshaymone.m1",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "com.akshaymone.m1" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "scheme": "m1",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "5e3fb3d2-3524-4d2f-8823-68c517b5b51f"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      "expo-web-browser"
    ]
  }
}
